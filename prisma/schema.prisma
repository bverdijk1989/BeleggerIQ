/// Status van een advies in de Decision History. `SUGGESTED` is de
/// default na opslag. `MARKED_DONE` zet de gebruiker zelf wanneer 'ie
/// de actie heeft uitgevoerd; `IGNORED` wanneer 'ie het advies bewust
/// niet opvolgt; `EXPIRED` wordt automatisch gezet als de
/// `expiresAt`-datum gepasseerd is.
enum DecisionStatus {
  SUGGESTED
  MARKED_DONE
  IGNORED
  EXPIRED
}

/// Type advies dat de cockpit heeft voorgesteld. Lijn 1-op-1 met
/// `DashboardActionType` uit `lib/analytics/actions`.
enum DecisionActionType {
  RISK_REDUCTION
  BUY_OPPORTUNITY
  HOLD_CASH
  DO_NOTHING
}

/// Bezorgkanalen voor notifications. EMAIL is v1; we modelleren ALERT_LOG
/// als een no-mail variant zodat een gebruiker die mails uitzet wél
/// nog een in-app log kan zien (zonder het schema later te breken).
enum NotificationChannel {
  EMAIL
  ALERT_LOG
}

/// Bezorg-status. Een digest-run kan meerdere events SENT_AS_DIGEST
/// markeren zodat we ze niet later nog eens als instant-alert sturen.
enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED_BY_PREFERENCE
  SENT_AS_DIGEST
}

/// Type van een broker-transactie.
///
/// - **BUY** / **SELL** muteren `Holding.quantity` en triggeren cost-basis-rekenen.
/// - **DIVIDEND** is bruto-dividend; bijbehorende bronbelasting komt als losse `TAX`-rij.
/// - **INTEREST** is broker-rente (debit/credit) op de cash-balans.
/// - **FEE** zijn losse fees buiten BUY/SELL om (custody, currency-conversion-fees).
/// - **TAX** is alle vorm van inhouding (DIY-tax, dividend-withholding).
/// - **CASH** is een storting/opname (deposit/withdrawal).
/// - **FX** is een EUR↔USD-conversie tussen cash-pots; quantity = bedrag in `currency`,
///   metadata bevat de tegenovergestelde leg.
/// - **ADJUSTMENT** is een handmatige correctie (typo, forex-correctie achteraf).
enum TransactionType {
  BUY
  SELL
  DIVIDEND
  INTEREST
  FEE
  TAX
  CASH
  FX
  ADJUSTMENT
}
