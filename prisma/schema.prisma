// BeleggerIQ 2.0 - Prisma schema
// PostgreSQL-ready. Ontworpen voor portfolio-analyse, factor scoring,
// risicoanalyse, market regime tracking, strategy presets en backtests.
//
// Conventies:
//  - Alle primaire keys zijn cuid (stringbar + DB-agnostisch).
//  - Alle monetaire waarden en ratio's zijn Decimal met vaste schaal.
//  - Tijdreeksen hebben een index op (resourceId, capturedAt).
//  - Json-kolommen worden gebruikt voor flexibele payloads die niet
//    query-ed hoeven te worden (goals, preferences, factorWeights, curves).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  USER + PROFIEL
// ============================================================

/// Centrale gebruiker van de app. Eén user kan meerdere portefeuilles,
/// watchlist items, strategy presets en backtest-runs bezitten.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  /// bcrypt-hash van het wachtwoord. NULL = user logt alleen in via
  /// magic-link of OAuth (geen password set). Module 18.
  passwordHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile                UserProfile?
  portfolios             Portfolio[]
  watchlistItems         WatchlistItem[]
  huntingSignalLogs      HuntingSignalLog[]
  strategyPresets        StrategyPreset[]
  backtestRuns           BacktestRun[]
  decisionSnapshots      DecisionSnapshot[]
  notificationDeliveries  NotificationDelivery[]
  auditEntries            AuditEntry[]
  behavioralWarningStates BehavioralWarningState[]
  financialGoals          FinancialGoal[]
  subscriptions           Subscription[]
  alerts                  Alert[]

  @@index([email])
}

/// Beleggersprofiel: horizon, doelen, risicobereidheid en policy.
/// Policy/goals/preferences zijn Json zodat productdefinities niet per
/// wijziging een migratie vragen. Hardgekoppelde velden zoals horizon en
/// contribution blijven typed voor query-performance.
model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  investorType         InvestorType        @default(LONG_TERM)
  objective            InvestmentObjective @default(BALANCED)
  riskTolerance        RiskTolerance       @default(BALANCED)
  investmentHorizonYrs Int                 @default(10)
  monthlyContribution  Decimal?            @db.Decimal(14, 2)
  baseCurrency         String              @default("EUR")
  taxResidency         String              @default("NL")

  goals         Json?
  preferences   Json?
  /// Gestructureerde PolicySettings (zie src/types/profile.ts).
  policy        Json?
  /// NotificationPreferences — { weeklyDigest, instantCriticalAlerts, watchlistAlerts }.
  /// Zie `src/lib/notifications/preferences.ts` voor de canonieke shape.
  /// Default (NULL) = alles aan zodat onboarding-users iets ontvangen.
  notifications Json?
  /// Voorkeurstaal voor de UI. M26 ondersteunt nu `nl` (default) en `en`.
  /// Zie `src/lib/i18n/locales.ts` voor de actuele set.
  locale        String    @default("nl")
  /// ISO-timestamp wanneer de gebruiker de onboarding-flow heeft afgerond.
  /// NULL = nog niet onboarded → app stuurt naar /onboarding.
  onboardedAt   DateTime?
  /// UX-mode (M28): BEGINNER toont alleen doelen/health/risico met
  /// educatieve microcopy; FOCUS toont alleen kernsignalen + briefing;
  /// EXPERT toont alle analytics, factor-breakdowns en macro-data.
  /// Default FOCUS — minimaal-maar-bruikbaar voor alle gebruikers.
  uxMode        UxMode    @default(FOCUS)
  /// Billing-tier (M29). Gedenormaliseerd voor snelle entitlement-lookup;
  /// `Subscription` is de bron-van-waarheid bij echte billing-integratie
  /// (Stripe/Mollie). Webhook-job sync't deze kolom. Default FREE.
  billingTier   BillingTier @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
//  PORTFOLIO + HOLDINGS
// ============================================================

/// Portefeuille: container voor posities, snapshots en backtest-runs.
/// `isPrimary` markeert de standaardportefeuille van een user.
model Portfolio {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  baseCurrency String  @default("EUR")
  isPrimary    Boolean @default(false)
  /// Cash-balans in `baseCurrency`. Denormalized (één waarde per portfolio).
  /// Module 19 — bestaande snapshot-time-series in `PortfolioSnapshot.cashBalance`
  /// blijft de historische bron; deze kolom is de actuele state.
  cashBalance  Decimal @default(0) @db.Decimal(20, 2)

  holdings          Holding[]
  snapshots         PortfolioSnapshot[]
  backtestRuns      BacktestRun[]
  decisionSnapshots DecisionSnapshot[]
  transactions      Transaction[]
  taxValuations     TaxValuation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isPrimary])
}

/// Enkele positie in een portefeuille.
/// Unique(portfolioId, ticker) voorkomt duplicaten; broker-imports mergen op dit paar.
/// De "enrichment" velden (beta, volatility, scores) zijn optionele caches vanuit de
/// analytics engines — authoritative data zit in FactorSnapshot en PortfolioSnapshot.
model Holding {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  ticker     String
  isin       String?
  name       String
  assetClass AssetClass @default(EQUITY)
  currency   String     @default("EUR")

  quantity     Decimal  @db.Decimal(20, 8)
  avgCostPrice Decimal  @db.Decimal(20, 8)
  currentPrice Decimal? @db.Decimal(20, 8)

  sector String?
  region String?

  // --- Enrichment cache ---
  beta            Decimal? @db.Decimal(10, 4)
  volatility      Decimal? @db.Decimal(10, 6)
  moatLikeScore   Decimal? @db.Decimal(5, 4)
  targetWeight    Decimal? @db.Decimal(5, 4)
  convictionScore Decimal? @db.Decimal(5, 4)

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, ticker])
  @@index([portfolioId])
  @@index([ticker])
  @@index([isin])
}

// ============================================================
//  SNAPSHOTS (TIJDREEKSEN)
// ============================================================

/// Tijdreeks-snapshot van een portefeuille voor performance- en risk analytics.
/// Denormaliseert enkele headline-velden (value, cost, cash) voor snelle queries;
/// rijkere metrics gaan in `metrics` als Json.
model PortfolioSnapshot {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  capturedAt  DateTime @default(now())
  totalValue  Decimal  @db.Decimal(20, 2)
  totalCost   Decimal  @db.Decimal(20, 2)
  cashBalance Decimal  @default(0) @db.Decimal(20, 2)

  unrealizedPnl    Decimal? @db.Decimal(20, 2)
  unrealizedPnlPct Decimal? @db.Decimal(10, 6)
  volatility       Decimal? @db.Decimal(10, 6)
  drawdown         Decimal? @db.Decimal(10, 6)

  regimeLabel RegimeLabel?
  healthGrade HealthGrade?
  healthScore Decimal?     @db.Decimal(5, 2)

  /// Rijkere, flexibele metrics (exposure, factor alignment, etc).
  metrics Json?

  @@index([portfolioId, capturedAt])
}

/// Markt-brede snapshot: regime, volatility, rente, inflatie en breadth.
/// Onafhankelijk van een user — wordt per run van de regime-engine geschreven.
model MarketSnapshot {
  id         String   @id @default(cuid())
  capturedAt DateTime @default(now())

  regimeLabel      RegimeLabel @default(UNKNOWN)
  regimeConfidence Decimal?    @db.Decimal(5, 4)
  volatilityIndex  Decimal?    @db.Decimal(10, 4)
  interestRate10y  Decimal?    @db.Decimal(6, 4)
  inflationYoy     Decimal?    @db.Decimal(6, 4)
  breadthScore     Decimal?    @db.Decimal(5, 4)

  /// Array van indicator-objecten (zie MarketRegimeIndicator type).
  indicators Json?
  narrative  String?
  source     String?

  @@index([capturedAt])
  @@index([regimeLabel, capturedAt])
}

/// Per-ticker factor snapshot. `model` onderscheidt meerdere scorende
/// engines (bv. "default", "experimental"). Unique per (ticker, capturedAt, model)
/// maakt een run idempotent.
model FactorSnapshot {
  id         String   @id @default(cuid())
  ticker     String
  isin       String?
  capturedAt DateTime @default(now())
  model      String   @default("default")

  valueScore    Decimal? @db.Decimal(6, 4)
  qualityScore  Decimal? @db.Decimal(6, 4)
  momentumScore Decimal? @db.Decimal(6, 4)
  lowVolScore   Decimal? @db.Decimal(6, 4)
  growthScore   Decimal? @db.Decimal(6, 4)
  dividendScore Decimal? @db.Decimal(6, 4)
  sizeScore     Decimal? @db.Decimal(6, 4)

  composite  Decimal? @db.Decimal(6, 4)
  percentile Decimal? @db.Decimal(5, 4)
  confidence Decimal? @db.Decimal(5, 4)

  /// Gedenormaliseerde fundamentals (FundamentalsSnapshot shape) voor audit.
  fundamentals Json?
  source       String?

  @@unique([ticker, capturedAt, model])
  @@index([ticker, capturedAt])
  @@index([capturedAt])
}

// ============================================================
//  STRATEGIE + BACKTEST
// ============================================================

/// Herbruikbare strategy preset. Publieke presets hebben `ownerId = null`
/// en `isPublic = true`; privé presets horen bij een user.
model StrategyPreset {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String
  type        StrategyType @default(FACTOR)
  tags        String[]     @default([])
  isPublic    Boolean      @default(false)

  ownerId String?
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  rebalance         RebalanceFrequency @default(MONTHLY)
  maxPositions      Int?
  maxPositionWeight Decimal?           @db.Decimal(5, 4)
  minMarketCap      Decimal?           @db.Decimal(20, 2)

  /// FactorWeights object.
  factorWeights  Json
  /// Vrij filterobject voor de screener.
  universeFilter Json?

  backtestRuns BacktestRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([isPublic, type])
}

/// Uitvoering van een backtest. Config en rijke output (equity curve etc.)
/// staan als Json; headline-metrics staan als Decimal voor sortering in UI.
model BacktestRun {
  id     String         @id @default(cuid())
  name   String
  status BacktestStatus @default(PENDING)

  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId String?
  portfolio   Portfolio?      @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  strategyId  String?
  strategy    StrategyPreset? @relation(fields: [strategyId], references: [id], onDelete: SetNull)

  startDate      DateTime
  endDate        DateTime
  initialCapital Decimal  @db.Decimal(20, 2)
  baseCurrency   String   @default("EUR")

  // Resultaat-metrics (fracties tenzij anders aangegeven)
  totalReturn Decimal? @db.Decimal(10, 6)
  cagr        Decimal? @db.Decimal(10, 6)
  volatility  Decimal? @db.Decimal(10, 6)
  sharpe      Decimal? @db.Decimal(10, 4)
  sortino     Decimal? @db.Decimal(10, 4)
  maxDrawdown Decimal? @db.Decimal(10, 6)
  calmar      Decimal? @db.Decimal(10, 4)
  winRate     Decimal? @db.Decimal(5, 4)
  turnover    Decimal? @db.Decimal(10, 6)
  finalValue  Decimal? @db.Decimal(20, 2)
  tradesCount Int?

  /// BacktestConfig (zie src/types/backtest.ts).
  config          Json
  /// Array van EquityPoint.
  equityCurve     Json?
  /// BenchmarkComparison.
  benchmark       Json?
  /// Array van RegimeBreakdown.
  regimeBreakdown Json?
  errorMessage    String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId, startedAt])
  @@index([strategyId])
  @@index([portfolioId])
  @@index([status])
}

// ============================================================
//  HUNTING LIST  (voorheen: WATCHLIST)
// ============================================================

/// Actieve kansenlijst: tickers die een user volgt, aangevuld met
/// target-zone- en valuation-band-triggers zodat de lijst aangeeft
/// **wanneer** een aandeel koopwaardig onderzocht moet worden.
///
/// - `targetPrice`/`targetPriceHigh` vormen samen een target-zone;
///   wanneer `targetPriceHigh` null is, wordt `targetPrice` als
///   enkele buy-drempel gebruikt met `buyZoneTolerance` als marge.
/// - `buyZoneTolerance` is een fractie (bv. 0.05 = 5%); default 0.05.
/// - `valuationMaxPE` / `valuationMinFcfYield` zijn optionele
///   user-gedefinieerde valuation-drempels. Detectie is off-by-default.
/// - Unique(userId, ticker) voorkomt dubbele entries bij herhaald toevoegen.
model WatchlistItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ticker String
  name   String?
  note   String?

  // Target-zone config
  targetPrice      Decimal? @db.Decimal(20, 8)
  targetPriceHigh  Decimal? @db.Decimal(20, 8)
  buyZoneTolerance Float?

  // Valuation-band config (user-defined triggers)
  valuationMaxPE       Float?
  valuationMinFcfYield Float?

  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  signalLogs HuntingSignalLog[]

  @@unique([userId, ticker])
  @@index([userId, addedAt])
  @@index([ticker])
}

/// Append-only log van afgevuurde hunting-list triggers. Elk record
/// documenteert **wanneer** een specifieke trigger voor het eerst (of
/// opnieuw) actief werd, welke ernst, onder welke prijs/fundamentals.
///
/// De loader schrijft **alleen** een nieuw record wanneer er nog geen
/// niet-verlopen log van hetzelfde type bestaat. Zo blijft het log
/// een opportunity-history i.p.v. een tick-stream.
model HuntingSignalLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  watchlistItemId String?
  watchlistItem   WatchlistItem? @relation(fields: [watchlistItemId], references: [id], onDelete: SetNull)

  ticker      String
  triggerType String // "target-zone-reached" | "target-zone-near" | "valuation-band-reached"
  severity    String // "LOW" | "MEDIUM" | "HIGH"

  price     Decimal? @db.Decimal(20, 8)
  currency  String?
  pe        Float?
  fcfYield  Float?
  rationale String? // JSON-stringified array of NL-bullets
  note      String?

  firedAt   DateTime @default(now())
  expiresAt DateTime

  @@index([userId, ticker, firedAt])
  @@index([userId, firedAt])
  @@index([expiresAt])
}

/// Decision History — append-only log van adviezen die de cockpit aan
/// de gebruiker heeft voorgesteld. Per advies wordt een snapshot
/// vastgelegd zodat we achteraf kunnen evalueren: welke acties zijn
/// daadwerkelijk uitgevoerd, welke genegeerd, welke verlopen?
///
/// Conventies:
/// - **Append-only.** We muteren `status` en `statusUpdatedAt` in-place,
///   maar de oorspronkelijke advies-payload (`actionType`, `symbol`,
///   `shares`, `amount`, `rationale`, `confidence`) blijft onaangeroerd.
/// - **Geen brokerkoppeling.** "marked_done" betekent dat de gebruiker
///   zegt het uitgevoerd te hebben — wij verifieren dat niet.
/// - **Idempotent op (userId, suggestedAt-bucket, actionType, symbol).**
///   Repository gebruikt een 1-uur-bucket zodat repeated dashboard-loads
///   geen duplicaten produceren.
model DecisionSnapshot {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)

  /// Stabiel id uit de dashboard-action (bv. "RISK_REDUCTION:RHM").
  /// Niet uniek — de gebruiker kan meerdere snapshots voor dezelfde
  /// (type, symbol)-combinatie hebben, maar telkens 1 per uur-bucket.
  decisionKey String

  suggestedAt     DateTime @default(now())
  /// Begin van de uur-bucket waarin dit advies viel — gebruikt voor
  /// idempotente upserts.
  suggestedBucket DateTime

  actionType   DecisionActionType
  symbol       String?
  shares       Int?
  amount       Decimal?           @db.Decimal(20, 2)
  baseCurrency String             @default("EUR")

  /// Eén-zin uitleg uit de engine (action.title of action.reason).
  title        String
  /// Volledige rationale-string (engine-reason of explainer-narrative).
  rationale    String?
  /// 0..1 — overgenomen uit dashboard-action.
  confidence   Decimal @db.Decimal(5, 4)
  /// Engine-bron ("rebalance-engine" / "action-engine" / etc.).
  sourceEngine String

  status          DecisionStatus @default(SUGGESTED)
  statusUpdatedAt DateTime       @default(now())
  /// Optionele user-note bij `marked_done` of `ignored`.
  statusNote      String?

  /// Vervaldatum: na deze datum wordt de status auto-omgezet naar EXPIRED
  /// door het housekeeping-proces (`reapDecisionSnapshots`).
  expiresAt DateTime

  @@unique([userId, suggestedBucket, decisionKey])
  @@index([userId, suggestedAt])
  @@index([userId, status])
  @@index([expiresAt])
}

// ============================================================
//  TRANSACTIONS — broker-import & cost-basis bron
// ============================================================

/// Eén broker-uitvoering. Append-only, mutable alleen via correctie-records
/// (`type=ADJUSTMENT`). De cost-basis-engine (FIFO/LIFO) leest hier z'n
/// werkelijke exposure uit, zodat realized PnL, fees, dividenden en
/// withholding-tax voor jaarrapportages reproduceerbaar zijn.
///
/// Conventies:
/// - **`type`** is een TransactionType — BUY/SELL muteren positie,
///   DIVIDEND/INTEREST/TAX/FEE/CASH/FX zijn cash-only flows.
/// - **`quantity`/`price`/`fee`** in de **transactiemunt** (`currency`).
///   Conversie naar base-currency gebeurt aan view-side; we slaan de
///   originele waarden op zodat re-rate naar EUR achteraf nog kan.
/// - **`signedAmount`** = (quantity*price ± fee) afhankelijk van type;
///   genormaliseerde voorteken-conventie staat in
///   `src/lib/transactions/normalize.ts`. Reden: queries als
///   "totale fees in 2026" mogen geen typecast nodig hebben.
/// - **Idempotentie**: unique key `(portfolioId, externalId)` waar
///   `externalId` typisch een hash is van (executedAt, ticker, qty,
///   price, source). Re-import van dezelfde CSV → geen duplicaten.
/// - **`metadata`** Json voor parser-specifieke velden (bv. DEGIRO
///   "Order Id", "Beurs", FX-rate die de broker noteerde).
model Transaction {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  ticker String?
  isin   String?
  name   String?

  type TransactionType

  quantity     Decimal? @db.Decimal(20, 8)
  price        Decimal? @db.Decimal(20, 8)
  fee          Decimal? @db.Decimal(20, 4)
  /// Genormaliseerd, ondertekend cash-effect in `currency`. Negatief =
  /// uitgaande cash (BUY, FEE, TAX), positief = inkomend (SELL, DIVIDEND).
  signedAmount Decimal? @db.Decimal(20, 4)

  currency String @default("EUR")

  executedAt DateTime

  /// Stabiele dedup-id (typisch hash). Per portfolio uniek zodat re-import
  /// van dezelfde CSV niet dupliceert.
  externalId String?
  source     String? // "degiro" | "manual" | ...

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, externalId])
  @@index([portfolioId, executedAt])
  @@index([portfolioId, type, executedAt])
  @@index([ticker, executedAt])
}

// ============================================================
//  TAX — manuele box-3 peildatum-waarderingen
// ============================================================

/// Handmatig ingevoerde portefeuille-waarde op een peildatum (typisch
/// 1 jan van het belastingjaar) wanneer er geen `PortfolioSnapshot` is
/// op of nabij die datum.
///
/// Conventies:
///   - **Eén entry per (portfolio, peilYear).** Unique constraint
///     voorkomt dubbele invoer; updates gaan via upsert.
///   - **`asOf`** is altijd een YYYY-01-01 datum. We slaan 'em apart
///     op zodat de UI eventuele afwijking (bv. 31-12) kan tonen.
///   - **`baseCurrency`** komt uit de portefeuille; we slaan 'em mee
///     zodat een latere base-currency-wijziging deze record niet
///     reinterpreteert.
model TaxValuation {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  peilYear     Int
  asOf         DateTime
  totalValue   Decimal  @db.Decimal(20, 2)
  baseCurrency String   @default("EUR")
  /// Optioneel — broker- of bank-statement waar de waarde vandaan komt.
  source       String?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([portfolioId, peilYear])
  @@index([portfolioId])
}

// ============================================================
//  FACTOR DRIFT MONITOR (M19 — skeleton)
// ============================================================

/// Rolling factor-effectiveness snapshot. Per (factor, capturedAt)
/// noteren we de Information Coefficient (IC) over een rolling window —
/// een klassiek maatstaf voor "voorspelt deze factor nog returns?".
///
/// **Doel**: detecteer wanneer een factor (quality, value, etc.) niet
/// meer signaal geeft. Een 12m-IC die nadert tot 0 betekent: de factor
/// is gestopt te werken op je universum, of de markt heeft ze
/// arbitraged. Trigger: notification `MODEL_DRIFT_DETECTED`.
///
/// Conventies:
///  - **`factor`** = `quality | value | momentum | lowVol`.
///  - **`window`** = "12m" | "6m" | "3m" — meerdere windows naast elkaar
///    om robuust te zijn tegen kortdurende noise.
///  - **`ic`** = Spearman-correlatie tussen factor-rank en
///    realized-return-rank op het einde van het window. Range [-1, 1].
///  - **`hitRate`** = fractie posities waar voorspelde rank-volgorde
///    klopte. 0.5 = random; > 0.55 = signaal.
///  - **`sampleSize`** = aantal posities in de meting; minder dan 30
///    levert geen signaal.
///
/// Idempotent op (factor, capturedAt, window) — re-runs van de drift-
/// job overschrijven niet onbedoeld historie.
model FactorDriftSnapshot {
  id         String   @id @default(cuid())
  factor     String
  window     String
  capturedAt DateTime @default(now())

  ic         Decimal? @db.Decimal(6, 4)
  hitRate    Decimal? @db.Decimal(5, 4)
  sampleSize Int

  /// Korte tekstuele duiding voor de UI (bv. "12m IC valt terug naar 0.04 — drift").
  narrative String?
  /// Vrije meta-bag (bv. universe-id, regime-context, top-decile spread).
  metadata  Json?

  @@unique([factor, capturedAt, window])
  @@index([factor, capturedAt])
}

// ============================================================
//  AUDIT LOG
// ============================================================

/// Append-only audit-log voor compliance + multi-user-discovery.
/// Pinpoints "wie wijzigde wat wanneer" voor security-relevante acties:
/// policy-update, manual tax-valuation, watchlist add/remove, transaction
/// import, demo-auth-disabled, etc.
///
/// Conventies:
/// - **Append-only**. Geen `update`-pad. Een gerepareerde state vereist
///   een nieuwe entry; de oude blijft staan voor traceability.
/// - **Geen PII in `before`/`after`**. Email-/IP-hashen reeds elders;
///   audit-rijen mogen alleen IDs + non-sensitive labels bevatten.
/// - **`category`** is een grove top-level cluster (`auth`, `policy`,
///   `tax`, `watchlist`, `transactions`, `notifications`, `system`),
///   `action` is de specifieke verb (`update`, `import`, `delete`, etc.).
/// - **`ipHash`** is optioneel — voor server-side acties waar geen IP
///   beschikbaar is, blijft 'em null.
model AuditEntry {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  category     String
  action       String
  /// Optionele resource-pointer (bv. portfolioId, transactionId).
  resourceType String?
  resourceId   String?

  /// Korte uitleg-string. Geen blob — dat zou een wildcard zijn voor PII.
  summary String

  /// JSON-context — alleen non-sensitive metadata (bv. before/after caps).
  /// PII (email, IP) hoort er NIET in.
  metadata Json?

  ipHash    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([category, createdAt])
  @@index([resourceType, resourceId])
}

// ============================================================
//  NOTIFICATIONS
// ============================================================

/// Append-only log van notificaties die we hebben gegenereerd én van
/// hun bezorging-status. Twee doelen:
///
///   1. **Idempotentie.** Elke event heeft een stabiele `key` (typisch
///      `<eventType>:<userId>:<bucket>:<salient>`). Eén row per key —
///      dus dezelfde rebalance-overschrijding triggert geen nieuwe
///      mail per cron-tick.
///
///   2. **Audit-trail.** "Wanneer hebben we welke alert verstuurd?"
///      Helpt bij compliance + debugging ("kreeg user X de regime-
///      switch melding wel?").
///
/// Conventies:
///   - `eventType` is een string-enum (zie `NotificationEventType` in
///     code) — geen Prisma-enum want de set groeit snel en we willen
///     geen migration-per-toevoeging.
///   - `key` is unique per (userId, key) — dat is de idempotency-grens.
///   - `status` muteert in-place (PENDING → SENT/FAILED), `attempts`
///     telt retries.
///   - `payload` Json bevat de gerenderde subject + text/html zodat
///     re-sending mogelijk is zonder de event opnieuw te berekenen.
model NotificationDelivery {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType String
  key       String
  channel   NotificationChannel @default(EMAIL)
  status    NotificationStatus  @default(PENDING)

  /// Onderwerp + body als gerenderd. Json zodat html optioneel kan zijn.
  payload Json
  /// Vrije meta-bag — bv. snapshotId, ticker, regimeBefore/After.
  context Json?

  attempts  Int     @default(0)
  lastError String?

  createdAt   DateTime  @default(now())
  sentAt      DateTime?
  /// Optioneel: gegroepeerd in een digest-run; dan staat hier de groep-id.
  digestRunId String?

  @@unique([userId, key])
  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([eventType, createdAt])
}

/// Magic-link login token. Single-use, time-bounded.
///
/// Conventies:
/// - **`tokenHash`** = SHA-256 hex van het ruwe token; we slaan het ruwe
///   token NOOIT op. Verificatie hashed de meegegeven raw-token en
///   vergelijkt timing-safe.
/// - **`expiresAt`** = `createdAt + 15 minuten` (default in code).
/// - **`usedAt`** wordt gezet bij eerste succesvolle exchange; daarna
///   wordt het token afgewezen (single-use).
/// - **`ipHash`** is optioneel en bevat een SHA-256 van het IP — voor
///   audit-trail zonder PII.
/// - Unique key `(email, tokenHash)` voorkomt dubbele insertions.
model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  ipHash    String?
  createdAt DateTime  @default(now())

  @@unique([email, tokenHash])
  @@index([email, createdAt])
  // Compound voor de hot-path "vind nog-geldig token voor deze email"
  // (consume-flow + housekeeping queries). Naast de losse expiresAt-
  // index zodat reaper op alleen `expiresAt` ook efficient blijft.
  @@index([email, expiresAt])
  @@index([expiresAt])
}

// ============================================================
//  BEHAVIORAL COACH — gebruiker-state per gedrags-signaal
// ============================================================

/// State-record voor één behavioral signal per (user, signalId).
///
/// **Engine-laag** (in `src/lib/analytics/behavioral`) genereert
/// signalen deterministisch op basis van portfolio + transacties. Deze
/// tabel slaat alleen de **gebruiker-interactie** op: wel/niet/snooze.
///
/// Conventies:
///  - `signalId` is stabiel per (signalKey, target), bv.
///    `OVERCONCENTRATION:ASML` of `OVERTRADING:GLOBAL`.
///  - `status = ACTIVE` is de default; afwezigheid van een rij = ACTIVE.
///  - `SNOOZED` records worden na `snoozedUntil` weer als ACTIVE
///    behandeld (engine + UI lezen `snoozedUntil` en interpreteren).
///  - `DISMISSED` is permanent — gebruiker kan handmatig terugzetten via
///    de /coach detail-pagina.
model BehavioralWarningState {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalId     String
  status       BehavioralWarningStatus @default(ACTIVE)
  /// Geldig wanneer status = SNOOZED. Daarna treedt het signaal weer
  /// als ACTIVE op zonder dat de gebruiker iets hoeft te doen.
  snoozedUntil DateTime?
  /// Optionele user-notitie ("ik handel deze zelf in juni").
  reasonNote   String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([userId, signalId])
  @@index([userId, status])
  @@index([snoozedUntil])
}

// ============================================================
//  FINANCIAL GOALS — gebruikersdoelen + projectie-input
// ============================================================

/// Financieel doel — pensioen, FIRE, dividendinkomen, vermogensgroei,
/// huis kopen, studie, buffer, of CUSTOM. Dient als input voor de
/// projectiecalculator + scenarios; wordt niet automatisch gekoppeld
/// aan transacties (de gebruiker beheert `currentAmount` zelf).
///
/// Conventies:
///  - **Bedragen** in `baseCurrency` (default EUR), Decimal voor precisie.
///  - **`expectedAnnualReturn`** is een fractie (0.06 = 6%/jaar). Default
///    afgeleid uit `riskProfile`.
///  - **`riskProfile`** stuurt zowel default-rendement als de breedte
///    van pessimistic/optimistic scenario-spread.
///  - **`isActive`** false = soft-delete; bewaart historiek voor audit.
model FinancialGoal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type GoalType
  /// Vrije naam — voor CUSTOM verplicht; voor preset-types optioneel
  /// (UI vult default-naam in).
  name String

  /// Doelbedrag in `baseCurrency`.
  targetAmount         Decimal @db.Decimal(20, 2)
  /// Streefdatum waarop het doelbedrag bereikt zou moeten zijn.
  targetDate           DateTime
  /// Maandelijkse inleg richting dit doel, in `baseCurrency`.
  monthlyContribution  Decimal @db.Decimal(14, 2) @default(0)
  /// Reeds opgebouwd bedrag (door de gebruiker bijgehouden).
  currentAmount        Decimal @db.Decimal(20, 2) @default(0)
  /// Verwacht jaarrendement, fractie. Default afhankelijk van riskProfile.
  expectedAnnualReturn Decimal @db.Decimal(6, 4)
  riskProfile          RiskTolerance @default(BALANCED)

  baseCurrency String @default("EUR")
  description  String?

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([userId, targetDate])
}

// ============================================================
//  BILLING — Subscription bron-van-waarheid (Stripe/Mollie-ready)
// ============================================================

/// Subscription per user. **Bron van waarheid** voor billing-state;
/// `UserProfile.billingTier` is een gedenormaliseerd cache.
///
/// **Externe integratie**: `externalId` houdt de Stripe/Mollie subscription-id.
/// Een webhook-handler (toekomst) updatet `status` + `currentPeriodEnd` +
/// sync't `UserProfile.billingTier`.
///
/// **Statussen** (Stripe-equivalent):
///   - TRIALING       — trial-periode actief
///   - ACTIVE         — betaald, in periode
///   - PAST_DUE       — betaling mislukt, grace-periode
///   - CANCELED       — opgezegd, mogelijk nog actief tot period-end
///   - EXPIRED        — periode afgelopen, geen toegang meer
///
/// Eén user kan meerdere historische subscription-rijen hebben (audit);
/// alleen de meest recente met status ACTIVE/TRIALING bepaalt de tier.
model Subscription {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier        BillingTier
  status      SubscriptionStatus  @default(ACTIVE)
  /// Externe subscription-id (Stripe/Mollie). Null bij interne testaccounts.
  externalId  String?
  /// Periode-startdatum (alleen geldig bij ACTIVE/PAST_DUE/CANCELED).
  currentPeriodStart DateTime?
  /// Periode-einddatum — bepaalt wanneer toegang vervalt na cancel.
  currentPeriodEnd   DateTime?
  /// Trial-eind, alleen relevant bij status=TRIALING.
  trialEndsAt        DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId, status])
  @@index([currentPeriodEnd])
  @@index([externalId])
}

// ============================================================
//  ALERTS — in-app notification center (los van outbound delivery)
// ============================================================

/// In-app alert: gegenereerd door de alerts-engine, getoond in het
/// notification-center (`/alerts`) en de bell-icoon-popover.
///
/// **Los van `NotificationDelivery`**: dat model is voor outbound
/// e-mail/digest-delivery; deze tabel is voor in-app read/unread/dismiss-
/// state. Een event kan zowel een Alert (in-app) als een
/// NotificationDelivery (e-mail) krijgen — `dedupeKey` is daarbij gelijk.
///
/// Conventies:
///  - **`dedupeKey`** unique per (userId, dedupeKey). Dezelfde gebeurtenis
///    twee keer triggeren produceert ÉÉN rij — idempotency-grens.
///  - **`status`** start UNREAD; gebruiker mark't 'em READ of DISMISSED.
///  - **`severity`** stuurt UI-toon (info/warning/critical) + sortering.
///  - **`context`** is een vrije Json bag voor template-rendering en
///    deeplinks (ticker, scoreBefore/After, regimeBefore/After, …).
model Alert {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AlertType
  severity    AlertSeverity  @default(INFO)
  status      AlertStatus    @default(UNREAD)
  /// Stabiele dedup-id, bv. "HEALTH_DROP:p-1:2026-05-10".
  dedupeKey   String
  /// Eénregelige titel voor lijst-weergave.
  title       String
  /// 1–4 zinnen NL plain text — voor popover én detail-pagina.
  body        String
  /// Vrije meta-bag (ticker, scoreBefore, regimeAfter, etc.).
  context     Json?
  /// Optionele app-route waar de gebruiker naartoe kan klikken.
  link        String?
  /// Wanneer de onderliggende gebeurtenis plaatsvond (≤ createdAt).
  occurredAt  DateTime
  readAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, dedupeKey])
  @@index([userId, status, occurredAt])
  @@index([userId, type, occurredAt])
}

