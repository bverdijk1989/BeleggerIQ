# BeleggerIQ 2.0 — nginx reverse proxy (pre-SSL)
#
# Deze config start bewust alleen op port 80. Dat is nodig omdat:
#   1. `listen 443 ssl` zonder `ssl_certificate`-paden = nginx test fail.
#   2. `certbot --nginx` detecteert deze port-80 vhost, rijgt er na SSL-
#      issuance een heel port-443 block aan vast (met ssl_certificate,
#      HSTS, http2) en redirect port 80 → 443.
#
# Installatie:
#   1. Vervang BELEGGERIQ_DOMAIN door je subdomain (bv. beleggeriq.aegiscore.nl).
#   2. sudo cp naar /etc/nginx/sites-available/beleggeriq.conf
#   3. sudo ln -s /etc/nginx/sites-available/beleggeriq.conf /etc/nginx/sites-enabled/
#   4. sudo nginx -t && sudo systemctl reload nginx
#   5. sudo certbot --nginx -d BELEGGERIQ_DOMAIN
#      (géén http:// prefix!)

server {
    listen 80;
    listen [::]:80;
    server_name BELEGGERIQ_DOMAIN;

    # Standaard security headers (certbot voegt HSTS op 443 toe na issuance).
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Max upload size voor DEGIRO CSV-imports (client-side al capped op 5MB).
    client_max_body_size 6M;

    # Let's Encrypt ACME challenge moet altijd via HTTP blijven.
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Next.js server op 127.0.0.1:3003
    location / {
        proxy_pass http://127.0.0.1:3003;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host  $host;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";

        # Timeouts afgestemd op onze provider-timeouts (max 12s history).
        proxy_connect_timeout   10s;
        proxy_send_timeout      30s;
        proxy_read_timeout      30s;
    }

    # Next.js static assets krijgen een lange cache-header.
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3003;
        proxy_cache_valid 200 365d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
}

# NB: na `certbot --nginx -d BELEGGERIQ_DOMAIN` voegt certbot automatisch een
# `server { listen 443 ssl http2; ... ssl_certificate ... }` block toe,
# plus een 80→443 redirect. Je hoeft die niet zelf te schrijven.
