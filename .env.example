# PostgreSQL connection string. Voorbeeld voor lokaal: postgres://user:pass@localhost:5432/beleggeriq
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/beleggeriq?schema=public"

# Application
NEXT_PUBLIC_APP_NAME="BeleggerIQ"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Zolang auth nog niet is aangesloten gebruikt de portfolio page deze e-mail
# om de demo-user (zie prisma/seed.ts) op te zoeken.
DEMO_USER_EMAIL="demo@beleggeriq.nl"

# Authenticatie (zie src/lib/auth/session.ts). Volgorde:
#   1. Signed cookie `biq_session` — HMAC met BIQ_SESSION_SECRET.
#   2. Dev-header `x-beleggeriq-user` — alleen wanneer NODE_ENV != production.
#   3. DEMO_USER_EMAIL fallback — alleen als BIQ_ALLOW_DEMO_AUTH=true.
# BIQ_SESSION_SECRET moet ≥ 32 tekens zijn (bv. openssl rand -hex 32).
BIQ_SESSION_SECRET=""
# Zet hieronder op "true" in staging/development; laat leeg in productie
# totdat er een echte login-flow is.
BIQ_ALLOW_DEMO_AUTH="true"

# Market data provider. "stub" levert deterministische fake data voor dev.
# Voeg later adapters toe voor yahoo / alphavantage / iex en wissel hier.
MARKET_DATA_PROVIDER="stub"

# Secrets voor echte providers (zodra de adapters landen). Nooit client-side.
# ALPHA_VANTAGE_API_KEY=
# IEX_CLOUD_API_KEY=

# AI provider (optioneel, later)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
